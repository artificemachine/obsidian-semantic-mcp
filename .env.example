OBSIDIAN_VAULTS=/path/to/vault1,/path/to/vault2
OBSIDIAN_VAULT=/path/to/vault
POSTGRES_PASSWORD=changeme
OLLAMA_URL=http://host.docker.internal:11434
PGDATA_PATH=/path/to/pgdata
# Dashboard bind address — defaults to 127.0.0.1 (loopback only). Docker
# Compose sets this to 0.0.0.0 internally; the `ports:` mapping already
# restricts host-side exposure to 127.0.0.1. Only override for native
# (non-Docker) installs that need the dashboard reachable from another host.
DASHBOARD_BIND=127.0.0.1
# Bearer token required by the dashboard's mutating endpoints (/api/reindex,
# /api/reindex/full, /api/prune, /api/ollama/start). If unset, a token is
# generated on first run and persisted at
# ~/.config/obsidian-semantic-mcp/dashboard_token (mode 0600).
DASHBOARD_TOKEN=
