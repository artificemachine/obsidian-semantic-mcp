docker-compose.override.yml
.serena/
excalidraw.log

# Accidental Windows/Git-Bash redirection artifact
nul

# Tool artifacts
.shipguard/
.voice-toolkit-project
.ship-check-passed

# /to-agents backup files (rule file edits preserve via git history; backups are off-tree)
.backups/
*.bak-to-agents-*

# pytest-cov output
.coverage
