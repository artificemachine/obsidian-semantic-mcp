# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*
# ...but the template MUST ship: `.env.*` above silently swallowed it, so no
# cloner ever received the file the README tells them to copy. Placeholders
# only — never put a real value in here.
!.env.example

