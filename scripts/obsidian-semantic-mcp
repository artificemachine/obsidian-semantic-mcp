#!/usr/bin/env bash
# Deprecated shim — kept for backwards compatibility with MCP configs that
# point directly at this script. New installs should use the Python entry
# point via `uv tool install obsidian-semantic-mcp` and set
# "command": "obsidian-semantic-mcp" in claude_desktop_config.json.
#
# Docker mode: set OSM_DOCKER=1 and OSM_PROJECT_ROOT in the MCP env block.
# See docs/plan_launcher_v0.9.5.md for migration instructions.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

if [[ -f "$PROJECT_ROOT/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  . "$PROJECT_ROOT/.env"
  set +a
fi

PYTHON_BIN="$PROJECT_ROOT/.venv/bin/python3"
if [[ ! -x "$PYTHON_BIN" ]]; then
  echo "obsidian-semantic-mcp: missing local runtime at $PYTHON_BIN" >&2
  exit 1
fi

# Delegate to the Python launcher — handles Docker mode and env validation.
export OSM_PROJECT_ROOT="${OSM_PROJECT_ROOT:-$PROJECT_ROOT}"
exec "$PYTHON_BIN" -m src.launcher "$@"
